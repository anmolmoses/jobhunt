# Required: Secret for encrypting API keys stored in the database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=

# AI Provider (at least one required for resume analysis, preferences, tailoring)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Job Search Providers (optional — LinkedIn, Indeed, Remotive, RemoteOK, Jobicy, HackerNews work without keys)
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Networking (optional)
HAPPENSTANCE_API_KEY=

# Company Logos (optional — 500K req/month free)
LOGODEV_API_KEY=

# Email Finder (optional — 25 req/month free)
HUNTER_API_KEY=

# Web Scraping (optional — self-hosted via Docker: docker run -p 3002:3002 mendableai/firecrawl)
# Enhances company intelligence, job descriptions, and map accuracy
FIRECRAWL_API_URL=
FIRECRAWL_API_KEY=

# Docker: expose on a different host port (default 3000)
# PORT=3000
